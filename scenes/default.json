{
  "render": {
    "width": 800,
    "aspect_ratio": [16, 9],
    "samples_per_pixel": 4,
    "max_depth": 10,
    "sky_color": [0.5, 0.5, 0.8],
    "ambient": [0.05, 0.05, 0.05]
  },

  "light": {
    "direction": [-1.0, -2.0, -1.0],
    "color": [0.9, 0.9, 0.9]
  },

  "camera": {
    "lookfrom": [13, 2, 3],
    "lookat": [0, 0, 0],
    "vup": [0, 1, 0],
    "vfov": 20.0,
    "aperture": 0.1,
    "focus_dist": 10.0
  },

  "materials": {
    "ground": {
      "type": "opaque",
      "texture": {
        "type": "checker",
        "color1": [0.2, 0.3, 0.1],
        "color2": [0.9, 0.9, 0.9],
        "frequency": 5
      },
      "specular": 0.4,
      "specular_pow": 32.0,
      "reflection": 0.0
    },
    "brown_matte": {
      "type": "opaque",
      "albedo": [0.4, 0.2, 0.1],
      "specular": 0.0,
      "specular_pow": 1.0,
      "reflection": 0.2
    },
    "cyan_reflective": {
      "type": "opaque",
      "albedo": [0.5, 0.6, 0.6],
      "specular": 0.8,
      "specular_pow": 16.0,
      "reflection": 0.9
    },
    "red_shiny": {
      "type": "opaque",
      "albedo": [0.9, 0.3, 0.2],
      "specular": 0.9,
      "specular_pow": 8.0,
      "reflection": 0.1
    }
  },

  "objects": [
    { "type": "sphere", "center": [0, -1000, 0], "radius": 1000.0, "material": "ground"          },
    { "type": "sphere", "center": [-4, 1, 2],    "radius": 1.0,    "material": "brown_matte"     },
    { "type": "sphere", "center": [0, 1, 1],     "radius": 1.0,    "material": "cyan_reflective" },
    { "type": "sphere", "center": [4, 1, 0],     "radius": 1.0,    "material": "red_shiny"       }
  ],

  "random_spheres": {
    "enabled": true,
    "grid_size": 11,
    "radius": 0.2,
    "reflective_chance": 0.3
  }
}
